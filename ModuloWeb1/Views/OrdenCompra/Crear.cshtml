<div class="container-fluid mt-4 px-4">
    <div class="card shadow-lg p-4">
        <h2 class="text-center text-primary mb-4">📋 Nueva Orden de Compra</h2>

        @if (ViewBag.Mensaje != null)
        {
            <div class="alert alert-success">
                <strong>@ViewBag.Mensaje</strong>
                @if (ViewBag.NumOrden != null)
                {
                    <br />
                    <a href="@Url.Action("DescargarPorNumero", new { numero = ViewBag.NumOrden })"
                       class="btn btn-sm btn-success mt-2">
                        📥 Descargar PDF
                    </a>
                    @if (!string.IsNullOrEmpty(ViewBag.DriveLink as string))
                    {
                        <a href="@ViewBag.DriveLink" target="_blank"
                           class="btn btn-sm btn-primary mt-2 ms-2">
                            ☁️ Ver en Drive
                        </a>
                    }
                }
            </div>
        }
        @if (ViewBag.WarningDrive != null)
        {
            <div class="alert alert-warning">@ViewBag.WarningDrive</div>
        }
        @if (ViewBag.Error != null)
        {
            <div class="alert alert-danger"><strong>@ViewBag.Error</strong></div>
        }

        <form id="formOrden" method="post" action="@Url.Action("Crear")">
            <input type="hidden" name="datosOrden" id="datosOrden" />

            <!-- ════ CABEZAL ════ -->
            <div class="row g-3 mb-3">
                <div class="col-md-4">
                    <label class="form-label fw-bold">Proveedor *</label>
                    <div class="input-group">
                        <select id="proveedorSelect" class="form-select" required>
                            <option value="">Seleccione un proveedor...</option>
                            @foreach (var p in ViewBag.Proveedores)
                            {
                                <option value="@p.Id"
                                        data-nombre="@p.Nombre"
                                        data-nit="@p.Nit"
                                        data-direccion="@p.Direccion"
                                        data-telefono="@p.Telefono"
                                        data-ciudad="@p.Ciudad"
                                        data-contacto="@p.Contacto"
                                        data-correo="@p.Correo">
                                    @p.Nombre
                                </option>
                            }
                        </select>
                        <button type="button" class="btn btn-outline-primary"
                                data-bs-toggle="modal" data-bs-target="#modalProveedor"
                                title="Crear nuevo proveedor">＋</button>
                        <button type="button" class="btn btn-outline-danger"
                                onclick="confirmarEliminarProveedor()"
                                title="Eliminar proveedor seleccionado">🗑</button>
                    </div>
                </div>
                <div class="col-md-2">
                    <label class="form-label fw-bold">Condiciones pago</label>
                    <input type="text" id="condiciones" class="form-control" value="30 días" />
                </div>
                <div class="col-md-2">
                    <label class="form-label fw-bold">Moneda</label>
                    <input type="text" id="moneda" class="form-control" value="COP" />
                </div>
                <div class="col-md-4">
                    <label class="form-label fw-bold">Comprador</label>
                    <input type="text" id="comprador" class="form-control" placeholder="Nombre del comprador" />
                </div>
                <div class="col-md-6">
                    <label class="form-label fw-bold">Entregar a (principal)</label>
                    <input type="text" id="entregarA" class="form-control" value="SUPLINDUSTRIA S.A.S." />
                </div>
                <div class="col-md-6">
                    <label class="form-label fw-bold">Entregar a (alterno)</label>
                    <input type="text" id="entregarAlterno" class="form-control" value="NA" />
                </div>
            </div>

            <!-- Info proveedor -->
            <div id="infoProveedor" class="alert alert-info d-none mb-3 py-2">
                <div class="row small" id="infoProv"></div>
            </div>

            <hr />
            <div class="d-flex justify-content-between align-items-center mb-2">
                <h5 class="text-secondary mb-0">🛒 Productos</h5>
                <button type="button" class="btn btn-outline-primary btn-sm" onclick="agregarFila()">
                    ➕ Agregar producto
                </button>
            </div>

            <!-- ════ TABLA PRODUCTOS ════ -->
            <div class="table-responsive">
                <table class="table table-bordered table-sm align-middle"
                       id="tablaProductos" style="font-size:0.82rem; min-width:1400px;">
                    <thead class="table-dark">
                        <tr>
                            <th style="width:40px"  class="text-center">Ln</th>
                            <th style="width:140px">Descripción *</th>
                            <th style="width:90px">Item</th>
                            <th style="width:90px">Catálogo</th>
                            <th style="width:90px">Modelo</th>
                            <th style="width:110px">F. Entrega</th>
                            <th style="width:60px">%IVA</th>
                            <th style="width:70px">Cantidad *</th>
                            <th style="width:70px">UM</th>
                            <th style="width:110px">Precio Unit. *</th>
                            <th style="width:65px">% Desc.</th>
                            <th style="width:110px">Valor Total</th>
                            <th style="width:40px"></th>
                        </tr>
                    </thead>
                    <tbody id="productosBody">
                        <tr class="fila-producto">
                            <td class="text-center numero-fila">1</td>
                            <td><input type="text"   class="form-control form-control-sm descripcion" placeholder="Descripción" /></td>
                            <td><input type="text"   class="form-control form-control-sm item"        placeholder="Item" /></td>
                            <td><input type="text"   class="form-control form-control-sm catalogo"    placeholder="Catálogo" /></td>
                            <td><input type="text"   class="form-control form-control-sm modelo"      placeholder="Modelo" /></td>
                            <td><input type="date"   class="form-control form-control-sm fecha-entrega" /></td>
                            <td><input type="number" class="form-control form-control-sm iva"         min="0" max="100" value="19"  step="0.1" onchange="calcularSubtotal(this)" /></td>
                            <td><input type="number" class="form-control form-control-sm cantidad"    min="1"           value="1"             onchange="calcularSubtotal(this)" /></td>
                            <td><input type="text"   class="form-control form-control-sm um"          value="UND" /></td>
                            <td><input type="number" class="form-control form-control-sm precio"      min="0" step="0.01" value="0"           onchange="calcularSubtotal(this)" /></td>
                            <td><input type="number" class="form-control form-control-sm descuento"   min="0" max="100" value="0"  step="0.1" onchange="calcularSubtotal(this)" /></td>
                            <td class="text-end fw-bold subtotal">$0.00</td>
                            <td class="text-center">
                                <button type="button" class="btn btn-sm btn-danger" onclick="eliminarFila(this)">✕</button>
                            </td>
                        </tr>
                    </tbody>
                    <tfoot>
                        <tr class="table-secondary">
                            <td colspan="11" class="text-end fw-bold">TOTAL:</td>
                            <td class="text-end fw-bold" id="totalGeneral">$0.00</td>
                            <td></td>
                        </tr>
                    </tfoot>
                </table>
            </div>

            <div class="text-center mt-3">
                <button type="button" class="btn btn-success btn-lg px-5" onclick="guardarOrden()">
                    💾 Generar Orden de Compra
                </button>
                <a href="@Url.Action("Lista")" class="btn btn-secondary btn-lg px-4 ms-2">
                    📋 Ver Órdenes
                </a>
            </div>
        </form>
    </div>
</div>

<!-- ════ MODAL: Crear Proveedor ════ -->
<div class="modal fade" id="modalProveedor" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header bg-primary text-white">
                <h5 class="modal-title">➕ Crear Nuevo Proveedor</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <div class="row g-3">
                    <div class="col-md-6">
                        <label class="form-label fw-bold">Nombre / Razón Social *</label>
                        <input type="text"  id="pNombre"    class="form-control" placeholder="Ej: Suministros XYZ S.A.S." />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label fw-bold">NIT / CC</label>
                        <input type="text"  id="pNit"       class="form-control" placeholder="Ej: 800987654-3" />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label fw-bold">Correo</label>
                        <input type="email" id="pCorreo"    class="form-control" placeholder="correo@empresa.com" />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label fw-bold">Teléfono</label>
                        <input type="text"  id="pTelefono"  class="form-control" placeholder="Ej: 604-8765432" />
                    </div>
                    <div class="col-md-8">
                        <label class="form-label fw-bold">Dirección</label>
                        <input type="text"  id="pDireccion" class="form-control" placeholder="Ej: Carrera 70 #45-30" />
                    </div>
                    <div class="col-md-4">
                        <label class="form-label fw-bold">Ciudad</label>
                        <input type="text"  id="pCiudad"    class="form-control" placeholder="Ej: Medellín" />
                    </div>
                    <div class="col-md-12">
                        <label class="form-label fw-bold">Nombre de Contacto</label>
                        <input type="text"  id="pContacto"  class="form-control" placeholder="Ej: Juan Pérez" />
                    </div>
                </div>
                <div id="modalError" class="alert alert-danger mt-3 d-none"></div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                <button type="button" class="btn btn-primary"   onclick="guardarProveedor()">💾 Guardar</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
// ════ TABLA ════

function agregarFila() {
    const tbody  = document.getElementById('productosBody');
    const nueva  = tbody.querySelector('.fila-producto').cloneNode(true);
    nueva.querySelectorAll('input').forEach(inp => {
        if      (inp.classList.contains('cantidad'))  inp.value = 1;
        else if (inp.classList.contains('iva'))       inp.value = 19;
        else if (inp.classList.contains('precio') || inp.classList.contains('descuento')) inp.value = 0;
        else if (inp.classList.contains('um'))        inp.value = 'UND';
        else inp.value = '';
    });
    nueva.querySelector('.subtotal').textContent = '$0.00';
    tbody.appendChild(nueva);
    renumerarFilas();
}

function eliminarFila(btn) {
    if (document.querySelectorAll('.fila-producto').length > 1) {
        btn.closest('.fila-producto').remove();
        renumerarFilas();
        calcularTotal();
    } else { alert('Debe haber al menos un producto.'); }
}

function renumerarFilas() {
    document.querySelectorAll('.numero-fila').forEach((td, i) => td.textContent = i + 1);
}

function calcularSubtotal(input) {
    const f   = input.closest('.fila-producto');
    const sub = (parseFloat(f.querySelector('.cantidad').value)  || 0)
              * (parseFloat(f.querySelector('.precio').value)    || 0)
              * (1 - (parseFloat(f.querySelector('.descuento').value) || 0) / 100)
              * (1 + (parseFloat(f.querySelector('.iva').value)       || 0) / 100);
    f.querySelector('.subtotal').textContent = '$' + sub.toFixed(2);
    calcularTotal();
}

function calcularTotal() {
    let total = 0;
    document.querySelectorAll('.fila-producto').forEach(f => {
        total += (parseFloat(f.querySelector('.cantidad').value)  || 0)
               * (parseFloat(f.querySelector('.precio').value)    || 0)
               * (1 - (parseFloat(f.querySelector('.descuento').value) || 0) / 100)
               * (1 + (parseFloat(f.querySelector('.iva').value)       || 0) / 100);
    });
    document.getElementById('totalGeneral').textContent = '$' + total.toFixed(2);
}

// ════ PROVEEDOR INFO ════

document.getElementById('proveedorSelect').addEventListener('change', function () {
    const opt = this.selectedOptions[0];
    if (!opt?.value) { document.getElementById('infoProveedor').classList.add('d-none'); return; }
    document.getElementById('infoProv').innerHTML = `
        <div class="col-md-3"><b>NIT:</b> ${opt.dataset.nit || 'N/A'}</div>
        <div class="col-md-3"><b>Ciudad:</b> ${opt.dataset.ciudad || 'N/A'}</div>
        <div class="col-md-3"><b>Contacto:</b> ${opt.dataset.contacto || 'N/A'}</div>
        <div class="col-md-3"><b>Teléfono:</b> ${opt.dataset.telefono || 'N/A'}</div>
        <div class="col-md-6"><b>Dirección:</b> ${opt.dataset.direccion || 'N/A'}</div>
        <div class="col-md-6"><b>Correo:</b> ${opt.dataset.correo || 'N/A'}</div>`;
    document.getElementById('infoProveedor').classList.remove('d-none');
});

// ════ GUARDAR ORDEN ════

function guardarOrden() {
    const idProveedor = document.getElementById('proveedorSelect').value;
    if (!idProveedor) { alert('⚠️ Seleccione un proveedor'); return; }

    const productos = [];
    let hayError = false;

    document.querySelectorAll('.fila-producto').forEach(f => {
        const desc   = f.querySelector('.descripcion').value.trim();
        const cant   = parseInt(f.querySelector('.cantidad').value)    || 0;
        const precio = parseFloat(f.querySelector('.precio').value)    || 0;
        if (!desc || cant <= 0 || precio <= 0) { hayError = true; return; }

        productos.push({
            NombreManual:   desc,
            Descripcion:    desc,
            Item:           f.querySelector('.item').value.trim(),
            Catalogo:       f.querySelector('.catalogo').value.trim(),
            Modelo:         f.querySelector('.modelo').value.trim(),
            FechaEntrega:   f.querySelector('.fecha-entrega').value,
            Iva:            parseFloat(f.querySelector('.iva').value)       || 0,
            Cantidad:       cant,
            Um:             f.querySelector('.um').value.trim() || 'UND',
            PrecioUnitario: precio,
            Descuento:      parseFloat(f.querySelector('.descuento').value) || 0
        });
    });

    if (hayError || productos.length === 0) {
        alert('⚠️ Complete Descripción, Cantidad y Precio en todos los productos');
        return;
    }

    document.getElementById('datosOrden').value = JSON.stringify({
        IdProveedor:    parseInt(idProveedor),
        Condiciones:    document.getElementById('condiciones').value,
        Moneda:         document.getElementById('moneda').value,
        Comprador:      document.getElementById('comprador').value,
        EntregarA:      document.getElementById('entregarA').value,
        EntregarAlterno: document.getElementById('entregarAlterno').value,
        Productos:      productos
    });
    document.getElementById('formOrden').submit();
}

// ════ CREAR PROVEEDOR ════

async function guardarProveedor() {
    const nombre = document.getElementById('pNombre').value.trim();
    if (!nombre) { mostrarErrorModal('El nombre es obligatorio'); return; }

    try {
        const res = await fetch('@Url.Action("CrearProveedor")', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({
                Nombre:    nombre,
                Nit:       document.getElementById('pNit').value.trim(),
                Correo:    document.getElementById('pCorreo').value.trim(),
                Telefono:  document.getElementById('pTelefono').value.trim(),
                Direccion: document.getElementById('pDireccion').value.trim(),
                Ciudad:    document.getElementById('pCiudad').value.trim(),
                Contacto:  document.getElementById('pContacto').value.trim()
            })
        });
        if (!res.ok) { mostrarErrorModal(await res.text()); return; }

        const prov = await res.json();
        const sel  = document.getElementById('proveedorSelect');
        const opt  = new Option(prov.nombre, prov.id);
        Object.assign(opt.dataset, {
            nombre: prov.nombre, nit: prov.nit, direccion: prov.direccion,
            telefono: prov.telefono, ciudad: prov.ciudad,
            contacto: prov.contacto, correo: prov.correo
        });
        sel.add(opt);
        sel.value = prov.id;
        sel.dispatchEvent(new Event('change'));

        ['pNombre','pNit','pCorreo','pTelefono','pDireccion','pCiudad','pContacto']
            .forEach(id => document.getElementById(id).value = '');
        document.getElementById('modalError').classList.add('d-none');
        bootstrap.Modal.getInstance(document.getElementById('modalProveedor')).hide();
    } catch(e) { mostrarErrorModal('Error: ' + e.message); }
}

function mostrarErrorModal(msg) {
    const el = document.getElementById('modalError');
    el.textContent = msg;
    el.classList.remove('d-none');
}

// ════ ELIMINAR PROVEEDOR ════

async function confirmarEliminarProveedor() {
    const sel  = document.getElementById('proveedorSelect');
    const id   = sel.value;
    const nom  = sel.selectedOptions[0]?.text;
    if (!id) { alert('Seleccione un proveedor primero'); return; }
    if (!confirm(`¿Eliminar el proveedor "${nom}"?\nEsto solo funciona si no tiene órdenes asociadas.`)) return;

    try {
        const res = await fetch('@Url.Action("EliminarProveedor")', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(parseInt(id))
        });
        if (!res.ok) { alert(await res.text()); return; }

        sel.querySelector(`option[value="${id}"]`).remove();
        sel.value = '';
        document.getElementById('infoProveedor').classList.add('d-none');
        alert(`✅ Proveedor "${nom}" eliminado.`);
    } catch(e) { alert('Error: ' + e.message); }
}

document.addEventListener('DOMContentLoaded', calcularTotal);
</script>
}

<style>
.table td, .table th { vertical-align: middle; }
#tablaProductos input { font-size: 0.8rem; }
</style>
